---
import AffiliateCard from './affiliate-card.astro';
import SiteLayout from '../layouts/site-layout.astro';
import { affiliates } from '../data/affiliates';
import { states, type StateData } from '../data/states';

interface Props {
  state: StateData;
}

const { state } = Astro.props;
const currentYear = new Date().getFullYear();

const northwestAffiliateUrl = affiliates.northwest;
const northwestPartnerName = 'Northwest Registered Agent';
const costBreakdown = state.costBreakdown ?? [];
const faqItems = state.faq ?? [];
const officialLinks = state.officialLinks ?? [];
const taxHighlights = state.taxHighlights ?? [];
const comparisonRows = state.comparisonRows ?? [];
const isResearchPending = state.contentStatus === 'placeholder';
const hasOfficialAgencyLink = Boolean(state.filingAgencyUrl) && !state.filingAgencyUrl.includes('example.com');
const hasDetailedSteps = !isResearchPending && state.steps.length > 0;
const hasFaqItems = !isResearchPending && faqItems.length > 0;
const hasProsCons = !isResearchPending && (state.proscons.pros.length > 0 || state.proscons.cons.length > 0);
const hasCostMeta = costBreakdown.some((row) => row.required || row.notes);

const formatCurrency = (value: number | null) => {
  if (value === null || value <= 0) {
    return 'Research pending';
  }

  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 0,
  }).format(value);
};

const formatRequirement = (value: boolean) => {
  if (isResearchPending) {
    return 'Research pending';
  }

  return value ? 'Yes' : 'No';
};

const formatLinkDomain = (rawUrl: string) => {
  try {
    return new URL(rawUrl).hostname.replace(/^www\./, '');
  } catch {
    return rawUrl;
  }
};

const introCopy = isResearchPending
  ? `We're still verifying the full ${state.name} LLC guide. This page only shows confirmed details and the safest next steps for now.`
  : state.intro;
const whatYoullNeedCopy = isResearchPending
  ? `Before you file in ${state.name}, confirm the state filing fee, the filing agency's instructions, and whether you want to handle the ${state.agentTerm} role yourself.`
  : state.whatYoullNeed;
const annualReportValue = isResearchPending ? 'Research pending' : state.annualReportDue;
const annualReportNote = isResearchPending
  ? "We're verifying the annual filing schedule."
  : state.annualReportNote;
const publicationRequirement = formatRequirement(state.requiresPublication);
const publicationValue = publicationRequirement === 'Research pending'
  ? publicationRequirement
  : publicationRequirement === 'No'
    ? 'None'
    : 'Required';
const publicationNote = publicationRequirement === 'Research pending'
  ? "We're verifying whether this state has a publication rule."
  : publicationRequirement === 'No'
    ? 'No newspaper requirement'
    : 'Publication step required';
const filingTimeValue = state.filingTimeShort && state.filingTimeShort !== 'Research pending'
  ? state.filingTimeShort
  : 'Research pending';
const filingTimeNote = filingTimeValue === 'Research pending'
  ? "We're verifying the standard processing time."
  : state.expeditedFee
    ? 'Standard estimate. Expedited available.'
    : 'Standard estimate.';
const filingFeeNote = 'One-time state filing fee';
const topRecommendationEyebrow = isResearchPending ? 'Verified basics only' : 'Best next step';
const topRecommendationTitle = isResearchPending
  ? `Use the official ${state.name} filing instructions first`
  : `For most founders, start with the ${state.name} filing itself`;
const topRecommendationCopy = isResearchPending
  ? `This guide is still in progress. Use the confirmed basics on this page, double-check the official filing instructions, and don't pay for a service until you know what ${state.name} actually requires.`
  : `If you live and operate in ${state.name}, the safest move is to file in ${state.name} directly. Compare LLC services only if you want help with privacy, document handling, or someone to do the filing for you.`;
const topRecommendationDetails = isResearchPending
  ? [
      {
        label: 'Safest default',
        description: 'Use the official filing instructions before you pay anyone.',
      },
      {
        label: 'Cheaper viable option',
        description: "Hold off on spending until you know the filing fee, the agent rule, and the annual-report reality here.",
      },
      {
        label: 'Avoid overpaying',
        description: "Don't buy EIN, compliance, or privacy add-ons from a provider before the basics are verified.",
      },
    ]
  : [
      {
        label: 'Safest default',
        description: `File directly with ${state.filingAgency} if you live and operate in ${state.name}.`,
      },
      {
        label: 'Cheaper viable option',
        description: `Handle the filing yourself if you're comfortable managing the ${state.agentTerm} role and the state paperwork.`,
      },
      {
        label: 'Avoid overpaying',
        description:
          annualReportValue === 'None'
            ? "Don't pay for bundled extras until you decide whether you even need filing help."
            : "Don't buy bundled extras until you confirm the filing fee, the annual schedule, and whether a service actually solves a problem for you.",
      },
    ];
const topRecommendationPrimaryHref = hasOfficialAgencyLink ? state.filingAgencyUrl : '#state-guide-basics';
const topRecommendationPrimaryLabel = hasOfficialAgencyLink
  ? 'See official filing instructions'
  : 'Review confirmed basics';

const title =
  state.seoTitle ??
  `How to Start an LLC in ${state.name} (${currentYear}) - Steps, Costs, Timeline | LLCAtlas`;
const description =
  state.seoDescription ??
  `Learn how to start an LLC in ${state.name} in ${currentYear}, including filing fees, timeline, core steps, and when using a registered agent service makes sense.`;
const pageUrl = `https://llcatlas.com/llc/${state.slug}/`;

const readyStateBySlug = new Map(
  states
    .filter((entry) => entry.contentStatus === 'ready')
    .map((entry) => [entry.slug, entry]),
);
const readyStateByName = new Map(
  Array.from(readyStateBySlug.values()).map((entry) => [entry.name, entry]),
);
const relatedStates = Array.from(readyStateBySlug.values()).filter(
  (entry) => entry.slug !== state.slug,
);
const getStatePath = (slug: string) => `/llc/${slug}/`;
const linkForStateName = (name: string): string | null => {
  if (name === state.name) return null;
  const target = readyStateByName.get(name);
  return target ? getStatePath(target.slug) : null;
};

const lastUpdatedIso = state.lastUpdated;
const lastUpdatedLabel = lastUpdatedIso
  ? new Date(`${lastUpdatedIso}T00:00:00Z`).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
  : null;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: pageUrl,
    inLanguage: 'en-US',
    about: `How to start an LLC in ${state.name}`,
    ...(lastUpdatedIso
      ? {
          datePublished: lastUpdatedIso,
          dateModified: lastUpdatedIso,
        }
      : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: 'https://llcatlas.com/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: `${state.name} LLC guide`,
        item: pageUrl,
      },
    ],
  },
  ...(hasFaqItems
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: faqItems.map((item) => ({
            '@type': 'Question',
            name: item.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: item.answer,
            },
          })),
        },
      ]
    : []),
];
---

<SiteLayout
  title={title}
  description={description}
  ogType="article"
  structuredData={structuredData}
  noindex={isResearchPending}
>
  <section class="space-y-8">
    <div class="space-y-6">
      <h1>How to start an LLC in {state.name}</h1>
      {lastUpdatedLabel && lastUpdatedIso && (
        <p class="text-[13px] uppercase tracking-[0.08em] text-ink-muted">
          Last updated <time datetime={lastUpdatedIso}>{lastUpdatedLabel}</time>
        </p>
      )}
      <p class="llc-section-copy text-ink-soft">{introCopy}</p>
    </div>

    <div class="llc-card-highlight space-y-6 !rounded-[1.5rem] !p-6 sm:!p-8">
      <div class="space-y-3">
        <p class="llc-helper">{topRecommendationEyebrow}</p>
        <h2>{topRecommendationTitle}</h2>
        <p class="llc-section-copy text-ink-soft">{topRecommendationCopy}</p>
      </div>

      <dl class="grid gap-y-5 border-t border-accent-soft/70 pt-5 md:grid-cols-3 md:gap-x-8 md:gap-y-0 md:divide-x md:divide-accent-soft/70">
        {
          topRecommendationDetails.map((item) => (
            <div class="space-y-1.5 md:px-6 md:first:pl-0 md:last:pr-0">
              <dt class="llc-helper">{item.label}</dt>
              <dd class="text-[15px] leading-7 text-ink-soft">{item.description}</dd>
            </div>
          ))
        }
      </dl>

      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href={topRecommendationPrimaryHref}
          target={hasOfficialAgencyLink ? '_blank' : undefined}
          rel={hasOfficialAgencyLink ? 'noopener noreferrer' : undefined}
          class="inline-flex min-h-11 items-center justify-center rounded-full bg-action px-5 py-3 text-sm font-semibold text-white transition hover:bg-action-hover"
        >
          {topRecommendationPrimaryLabel}
        </a>
        <a
          href="/best-llc-services"
          class="inline-flex min-h-11 items-center justify-center rounded-full border border-rule-strong px-5 py-3 text-sm font-semibold text-ink-strong transition hover:border-ink-muted hover:bg-surface"
        >
          Compare LLC services
        </a>
      </div>
    </div>

    <dl
      id="state-guide-basics"
      class="grid gap-px overflow-hidden border-y border-rule bg-rule sm:grid-cols-2 lg:grid-cols-4"
    >
      <div class="bg-surface px-5 py-5 sm:px-6 sm:py-6">
        <dt class="llc-helper">Filing fee</dt>
        <dd class="mt-3 text-[28px] font-semibold leading-tight tracking-tight text-ink-strong tabular-nums">{formatCurrency(state.filingFee)}</dd>
        <dd class="mt-1 text-[14px] leading-6 text-ink-muted">{filingFeeNote}</dd>
      </div>
      <div class="bg-surface px-5 py-5 sm:px-6 sm:py-6">
        <dt class="llc-helper">Processing time</dt>
        <dd class="mt-3 text-[28px] font-semibold leading-tight tracking-tight text-ink-strong">{filingTimeValue}</dd>
        <dd class="mt-1 text-[14px] leading-6 text-ink-muted">{filingTimeNote}</dd>
      </div>
      <div class="bg-surface px-5 py-5 sm:px-6 sm:py-6">
        <dt class="llc-helper">Annual report</dt>
        <dd class="mt-3 text-[28px] font-semibold leading-tight tracking-tight text-ink-strong">{annualReportValue}</dd>
        <dd class="mt-1 text-[14px] leading-6 text-ink-muted">{annualReportNote}</dd>
      </div>
      <div class="bg-surface px-5 py-5 sm:px-6 sm:py-6">
        <dt class="llc-helper">Publication</dt>
        <dd class="mt-3 text-[28px] font-semibold leading-tight tracking-tight text-ink-strong">{publicationValue}</dd>
        <dd class="mt-1 text-[14px] leading-6 text-ink-muted">{publicationNote}</dd>
      </div>
    </dl>
  </section>

  {
    officialLinks.length > 0 && (
      <section class="space-y-5">
        <h2>Official {state.name} resources</h2>

        <a
          href={officialLinks[0].url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block rounded-[14px] border border-accent-soft bg-surface-warm p-6 transition hover:border-accent sm:p-7"
        >
          <div class="flex items-center justify-between gap-3">
            <p class="llc-helper">Primary filing source</p>
            <span class="rounded-full bg-accent-soft px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-accent-ink whitespace-nowrap">
              Start here
            </span>
          </div>
          <p class="mt-3 text-[1.0625rem] font-semibold text-ink-strong sm:text-lg">
            {officialLinks[0].label}
          </p>
          <p class="mt-2 text-[14px] leading-6 text-ink-soft">
            Open this first. It's the official source for the filing itself.
          </p>
          <div class="mt-5 flex items-center justify-between gap-4">
            <p class="truncate text-[13px] leading-5 text-ink-muted">
              {formatLinkDomain(officialLinks[0].url)}
            </p>
            <span class="inline-flex shrink-0 items-center gap-1.5 text-sm font-semibold text-ink-strong transition group-hover:gap-2">
              Open
              <svg
                aria-hidden="true"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-3.5 w-3.5"
              >
                <path d="M3 8h10M9 4l4 4-4 4" />
              </svg>
            </span>
          </div>
        </a>

        {officialLinks.length > 1 && (
          <ul class="!space-y-0 divide-y divide-rule border-y border-rule">
            {officialLinks.slice(1).map((resource) => (
              <li>
                <a
                  href={resource.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center justify-between gap-4 py-4 transition hover:bg-surface-subtle sm:py-5"
                >
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-[15px] font-semibold text-ink-strong">{resource.label}</p>
                    <p class="mt-0.5 truncate text-[13px] leading-5 text-ink-muted">
                      {formatLinkDomain(resource.url)}
                    </p>
                  </div>
                  <span class="inline-flex shrink-0 items-center gap-1.5 text-sm font-semibold text-ink-soft transition group-hover:text-ink-strong group-hover:gap-2">
                    Open
                    <svg
                      aria-hidden="true"
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-3.5 w-3.5"
                    >
                      <path d="M3 8h10M9 4l4 4-4 4" />
                    </svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    )
  }

  <section class="space-y-5">
    <div class="space-y-4">
      <h2>How to form an LLC in {state.name}</h2>
      <p class="llc-section-copy">
        {hasDetailedSteps
          ? `The core steps most founders work through to form an LLC in ${state.name}.`
          : `We're still verifying the full step-by-step process for ${state.name}. Stick with the confirmed filing details and official resources before you submit anything.`}
      </p>
    </div>

    <div class="llc-card-subtle">
      <p class="llc-helper">Before you file</p>
      <h3 class="mt-2">What you'll need</h3>
      <p class="mt-3 llc-section-copy">{whatYoullNeedCopy}</p>
    </div>

    {
      hasDetailedSteps ? (
        <ol class="space-y-5">
          {
            state.steps.map((step, index) => (
              <li class="llc-card relative grid gap-3 sm:grid-cols-[auto_1fr] sm:gap-x-6">
                <span aria-hidden="true" class="llc-numeral">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <div class="min-w-0">
                  <h3>
                    <span class="sr-only">Step {index + 1} of {state.steps.length}: </span>
                    {step.title}
                  </h3>
                  <p class="mt-3 llc-section-copy">{step.description}</p>
                </div>
              </li>
            ))
          }
        </ol>
      ) : (
        <div class="llc-card">
          <p class="llc-section-copy text-ink-soft">
            The full walkthrough for {state.name} is still being finalized. For now, confirm the
            filing fee, the filing agency, the processing timeline, and any annual requirements
            before you submit anything yourself.
          </p>
        </div>
      )
    }
  </section>

  <AffiliateCard
    partnerName={northwestPartnerName}
    href={northwestAffiliateUrl}
    stateName={state.name}
    placement="inline"
    heading={`Our pick for ${state.name}: ${northwestPartnerName}`}
    description={`Want help filing your ${state.name} LLC? ${northwestPartnerName} is the service we point most first-time founders to — privacy first, no upsells at checkout, and transparent renewals.`}
    buttonLabel={`Start with ${northwestPartnerName}`}
    benefits={[
      `Acts as your ${state.agentTerm} — your home address stays off the public ${state.name} filing`,
      'No upsells or surprise add-ons at checkout',
      'Year one of registered agent service included',
    ]}
    ctaNote={`File your ${state.name} LLC with ${northwestPartnerName} handling the ${state.agentTerm} role.`}
  />

  <section class="space-y-5">
    <div class="space-y-4">
      <h2>{state.name} LLC cost breakdown</h2>
      <p class="llc-section-copy">
        See the upfront cost, the likely add-ons, and where the total climbs past the bare filing
        fee.
      </p>
    </div>

    <div class="llc-card overflow-hidden !p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-rule">
          <thead class="bg-surface-subtle">
            <tr>
              <th scope="col" class="llc-table-head px-5 py-4 text-left">Item</th>
              <th scope="col" class="llc-table-head px-5 py-4 text-right">Cost</th>
              {hasCostMeta && <th scope="col" class="llc-table-head px-5 py-4 text-left">Required?</th>}
              {hasCostMeta && <th scope="col" class="llc-table-head hidden px-5 py-4 text-left lg:table-cell">Notes</th>}
            </tr>
          </thead>
          <tbody class="divide-y divide-rule bg-surface">
            {
              costBreakdown.map((row) => (
                <tr class={row.isEmphasized ? 'bg-surface-warm' : undefined}>
                  <td class={['px-5 py-4', row.isEmphasized ? 'font-semibold text-ink-strong' : 'text-ink-soft'].join(' ')}>
                    {row.item}
                  </td>
                  <td class={['whitespace-nowrap px-5 py-4 text-right tabular-nums', row.isEmphasized ? 'font-semibold text-ink-strong' : 'text-ink-soft'].join(' ')}>
                    {row.cost}
                  </td>
                  {hasCostMeta && (
                    <td class="whitespace-nowrap px-5 py-4 text-ink-soft">{row.required ?? '—'}</td>
                  )}
                  {hasCostMeta && (
                    <td class="hidden px-5 py-4 text-ink-soft lg:table-cell">{row.notes ?? '—'}</td>
                  )}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {
    taxHighlights.length > 0 && (
      <section class="space-y-5">
        <div class="space-y-4">
          <h2>{state.name} tax and compliance notes</h2>
          <p class="llc-section-copy">
            This is where {state.name} gets less simple than the filing itself. The state-specific
            issues that generic LLC guides usually skip.
          </p>
        </div>

        <div class="space-y-5">
          {taxHighlights.map((item) => (
            <div class="llc-card-subtle">
              <p class="llc-section-copy">{item}</p>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    comparisonRows.length > 0 && (
      <section class="space-y-5">
        <div class="space-y-4">
          <h2>{state.name} vs other LLC states</h2>
          <p class="llc-section-copy">
            The simple comparison most founders actually want. Watch the ongoing state cost column.
            That's where states with cheap filing fees can still get expensive.
          </p>
        </div>

        <div class="llc-card overflow-hidden !p-0">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-rule">
              <thead class="bg-surface-subtle">
                <tr>
                  <th scope="col" class="llc-table-head px-5 py-4 text-left">State</th>
                  <th scope="col" class="llc-table-head px-5 py-4 text-left">Annual report</th>
                  <th scope="col" class="llc-table-head px-5 py-4 text-right">Upfront cost</th>
                  <th scope="col" class="llc-table-head px-5 py-4 text-right">Ongoing state cost</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-rule bg-surface">
                {comparisonRows.map((row) => {
                  const internalHref = linkForStateName(row.state);
                  return (
                    <tr class={row.state === state.name ? 'bg-surface-warm' : undefined}>
                      <th scope="row" class="px-5 py-4 text-left font-semibold text-ink-strong">
                        <div class="flex items-center gap-3">
                          {internalHref ? (
                            <a
                              href={internalHref}
                              class="whitespace-nowrap underline decoration-rule-strong underline-offset-4 transition hover:decoration-ink-soft"
                            >
                              {row.state}
                            </a>
                          ) : (
                            <span class="whitespace-nowrap">{row.state}</span>
                          )}
                          {row.state === state.name && (
                            <span class="rounded-full bg-accent-soft px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.06em] text-accent-ink whitespace-nowrap">
                              This page
                            </span>
                          )}
                        </div>
                      </th>
                      <td class="px-5 py-4 text-ink-soft">{row.annualReport}</td>
                      <td class="whitespace-nowrap px-5 py-4 text-right tabular-nums text-ink-soft">{row.upfrontCost}</td>
                      <td class="px-5 py-4 text-right text-ink-soft">{row.ongoingStateCost}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    )
  }

  {
    hasProsCons && (
      <section class="space-y-6">
        <div class="space-y-4">
          <h2>{state.name} LLC pros and cons</h2>
          <p class="llc-section-copy">
            Quick tradeoffs. Where {state.name} helps, where it adds friction, and what to watch
            before you file.
          </p>
        </div>

        <div class="grid gap-y-8 border-y border-rule py-7 md:grid-cols-2 md:gap-x-0 md:gap-y-0 md:divide-x md:divide-rule">
          <div class="md:pr-8 lg:pr-10">
            <p class="llc-helper">What works</p>
            <ul class="llc-bullet-list mt-4 text-ink-soft">
              {state.proscons.pros.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="md:pl-8 lg:pl-10">
            <p class="llc-helper">Watch out for</p>
            <ul class="llc-bullet-list mt-4 text-ink-soft">
              {state.proscons.cons.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </section>
    )
  }

  {
    relatedStates.length > 0 && (
      <section class="space-y-5">
        <div class="space-y-4">
          <h2>Other state guides</h2>
          <p class="llc-section-copy">
            If {state.name} isn't the right fit, these guides cover the other states most
            first-time founders compare it against.
          </p>
        </div>

        <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {relatedStates.map((entry) => (
            <li>
              <a
                href={getStatePath(entry.slug)}
                class="group flex items-center justify-between gap-3 rounded-[14px] border border-rule px-5 py-4 transition hover:border-rule-strong hover:bg-surface-subtle"
              >
                <span class="text-[15px] font-semibold text-ink-strong">
                  How to start an LLC in {entry.name}
                </span>
                <span class="inline-flex shrink-0 items-center gap-1.5 text-[13px] font-semibold text-ink-soft transition group-hover:gap-2 group-hover:text-ink-strong">
                  Open
                  <svg
                    aria-hidden="true"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-3.5 w-3.5"
                  >
                    <path d="M3 8h10M9 4l4 4-4 4" />
                  </svg>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <aside class="llc-card-subtle space-y-3 !rounded-[1.5rem]">
    <p class="llc-helper">Still picking a state?</p>
    <h3 class="text-xl">Not sure if {state.name} is the right state?</h3>
    <p class="llc-section-copy text-ink-soft">
      Wyoming, Delaware, and Nevada get the marketing. For most first-time founders, the best
      state to form an LLC is the one you live in. Read our plain-English guide on picking the
      right formation state before you file.
    </p>
    <a
      href="/best-state"
      class="inline-flex items-center gap-1.5 text-[15px] font-semibold text-ink-strong underline decoration-rule-strong underline-offset-4 transition hover:decoration-ink-soft"
    >
      Read the best-state guide
      <svg
        aria-hidden="true"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-3.5 w-3.5"
      >
        <path d="M3 8h10M9 4l4 4-4 4" />
      </svg>
    </a>
  </aside>

  {
    hasFaqItems && (
      <section class="space-y-5">
        <div class="space-y-4">
          <h2>FAQ</h2>
          <p class="llc-section-copy">
            The questions people ask right before they decide to file on their own or pay a
            service.
          </p>
        </div>

        <div class="space-y-5">
          {
            faqItems.map((item) => (
              <details class="group llc-card !p-0">
                <summary class="flex cursor-pointer items-start justify-between gap-4 px-5 py-5 text-lg font-semibold text-ink-strong sm:px-6">
                  <span>{item.question}</span>
                  <svg
                    aria-hidden="true"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="mt-2 h-3.5 w-3.5 shrink-0 text-ink-muted transition group-open:rotate-180"
                  >
                    <path d="M4 6l4 4 4-4" />
                  </svg>
                </summary>
                <div class="border-t border-rule px-5 py-5 sm:px-6">
                  <p class="llc-section-copy text-ink-soft">{item.answer}</p>
                </div>
              </details>
            ))
          }
        </div>
      </section>
    )
  }

  <div slot="sidebar" class="space-y-5">
    <AffiliateCard
      partnerName={northwestPartnerName}
      href={northwestAffiliateUrl}
      stateName={state.name}
      placement="sidebar"
      heading={`${northwestPartnerName} for ${state.name}`}
      description={`Acts as your ${state.agentTerm} so your home address stays off the public ${state.name} filing.`}
      buttonLabel={`Visit ${northwestPartnerName}`}
    />

    <div class="rounded-[14px] border border-rule px-5 py-5 text-[14px] leading-6 text-ink-soft sm:px-6">
      <p class="llc-helper">Or compare the field</p>
      <p class="mt-3">
        Not sold on one provider? See how the main LLC services stack up on price, privacy, and
        renewals.
      </p>
      <a
        href="/best-llc-services"
        class="mt-4 inline-flex items-center gap-1.5 text-[14px] font-semibold text-ink-strong underline decoration-rule-strong underline-offset-4 transition hover:decoration-ink-soft"
      >
        Compare LLC services
        <svg
          aria-hidden="true"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-3.5 w-3.5"
        >
          <path d="M3 8h10M9 4l4 4-4 4" />
        </svg>
      </a>
    </div>

    <div class="rounded-[14px] border border-rule px-5 py-5 text-[14px] leading-6 text-ink-soft sm:px-6">
      <p class="llc-helper">Still picking a state?</p>
      <p class="mt-3">
        Not sure if {state.name} is the right state? Read our guide to picking the best
        formation state before you file.
      </p>
      <a
        href="/best-state"
        class="mt-4 inline-flex items-center gap-1.5 text-[14px] font-semibold text-ink-strong underline decoration-rule-strong underline-offset-4 transition hover:decoration-ink-soft"
      >
        Read the best-state guide
        <svg
          aria-hidden="true"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-3.5 w-3.5"
        >
          <path d="M3 8h10M9 4l4 4-4 4" />
        </svg>
      </a>
    </div>
  </div>
</SiteLayout>
