---
import SiteLayout from '../layouts/site-layout.astro';
import type { StateData } from '../data/states';

interface Props {
  state: StateData;
}

const { state } = Astro.props;
const currentYear = new Date().getFullYear();
const costBreakdown = state.costBreakdown ?? [];
const faqItems = state.faq ?? [];
const officialLinks = state.officialLinks ?? [];
const taxHighlights = state.taxHighlights ?? [];
const comparisonRows = state.comparisonRows ?? [];
const isResearchPending = state.contentStatus === 'placeholder';
const hasOfficialAgencyLink = Boolean(state.filingAgencyUrl) && !state.filingAgencyUrl.includes('example.com');
const hasDetailedSteps = !isResearchPending && state.steps.length > 0;
const hasFaqItems = !isResearchPending && faqItems.length > 0;
const hasProsCons = !isResearchPending && (state.proscons.pros.length > 0 || state.proscons.cons.length > 0);
const hasCostMeta = costBreakdown.some((row) => row.required || row.notes);

const formatCurrency = (value: number | null) => {
  if (value === null || value <= 0) {
    return 'Research pending';
  }

  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 0,
  }).format(value);
};

const formatRequirement = (value: boolean) => {
  if (isResearchPending) {
    return 'Research pending';
  }

  return value ? 'Yes' : 'No';
};

const introCopy = isResearchPending
  ? `We are still verifying the full ${state.name} LLC guide. This page only shows confirmed details and the safest next steps for now.`
  : state.intro;
const whatYoullNeedCopy = isResearchPending
  ? `Before you file in ${state.name}, confirm the state filing fee, filing agency instructions, and whether you want to handle the ${state.agentTerm} role yourself.`
  : state.whatYoullNeed;
const annualReportValue = isResearchPending
  ? 'Research pending'
  : state.annualReportDue.toLowerCase().includes('none')
    ? 'None'
    : state.annualReportDue;
const annualReportNote = isResearchPending
  ? 'We are verifying the annual filing schedule.'
  : state.annualReportDue.toLowerCase().includes('none')
    ? 'No recurring state filings'
    : state.annualReportDue;
const publicationRequirement = formatRequirement(state.requiresPublication);
const publicationValue = publicationRequirement === 'Research pending'
  ? publicationRequirement
  : publicationRequirement === 'No'
    ? 'None'
    : 'Required';
const publicationNote = publicationRequirement === 'Research pending'
  ? 'We are verifying whether this state has a publication rule.'
  : publicationRequirement === 'No'
    ? 'No newspaper requirement'
    : 'Publication step required';
const filingTimeValue = state.filingTimeShort && state.filingTimeShort !== 'Research pending'
  ? state.filingTimeShort
  : 'Research pending';
const filingTimeNote = filingTimeValue === 'Research pending'
  ? 'We are verifying the standard processing time.'
  : state.expeditedFee
    ? 'Standard estimate. Expedited available.'
    : 'Standard estimate.';
const filingFeeNote = 'One-time state filing fee';
const topRecommendationEyebrow = isResearchPending ? 'Verified basics only' : 'Best next step';
const topRecommendationTitle = isResearchPending
  ? `Use the official ${state.name} filing instructions first`
  : `For most founders, start with the ${state.name} filing itself`;
const topRecommendationCopy = isResearchPending
  ? `This guide is still in progress. Use the confirmed basics on this page, double-check the official filing instructions, and avoid making a paid service decision until you know what ${state.name} actually requires.`
  : `If you live and operate in ${state.name}, the safest default is usually to file in ${state.name} directly. Compare LLC services only if you want help with privacy, document handling, or having someone else handle the filing steps.`;
const topRecommendationDetails = isResearchPending
  ? [
      {
        label: 'Safest default',
        description: 'Use the official filing instructions before you make any paid service decision.',
      },
      {
        label: 'Cheaper viable option',
        description: 'Wait to spend money until you know the filing fee, the agent requirement, and the annual-report reality in this state.',
      },
      {
        label: 'Avoid overpaying',
        description: 'Do not buy EIN, compliance, or privacy add-ons from a provider before the state basics are verified.',
      },
    ]
  : [
      {
        label: 'Safest default',
        description: `File directly with ${state.filingAgency} if you live and operate in ${state.name}.`,
      },
      {
        label: 'Cheaper viable option',
        description: `Handle the filing yourself if you are comfortable managing the ${state.agentTerm} role and the state paperwork.`,
      },
      {
        label: 'Avoid overpaying',
        description:
          annualReportValue === 'None'
            ? 'Do not pay for bundled extras before you decide whether you even need filing help.'
            : 'Do not buy bundled extras until you confirm the filing fee, the annual schedule, and whether a service is solving a real problem for you.',
      },
    ];
const topRecommendationPrimaryHref = hasOfficialAgencyLink ? state.filingAgencyUrl : '#state-guide-basics';
const topRecommendationPrimaryLabel = hasOfficialAgencyLink
  ? 'See official filing instructions'
  : 'Review confirmed basics';

const title = `How to Start an LLC in ${state.name} (${currentYear}) - Steps, Costs, Timeline | LLCAtlas`;
const description = `Learn how to start an LLC in ${state.name} in ${currentYear}, including filing fees, timeline, core steps, and when using a registered agent service makes sense.`;
const pageUrl = `https://llcatlas.com/llc/${state.slug}/`;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: pageUrl,
    inLanguage: 'en-US',
    about: `How to start an LLC in ${state.name}`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: 'https://llcatlas.com/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: `${state.name} LLC guide`,
        item: pageUrl,
      },
    ],
  },
  ...(hasFaqItems
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: faqItems.map((item) => ({
            '@type': 'Question',
            name: item.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: item.answer,
            },
          })),
        },
      ]
    : []),
];
---

<SiteLayout
  title={title}
  description={description}
  ogType="article"
  structuredData={structuredData}
>
  <section class="space-y-8">
    <div class="space-y-6">
      <h1>How to start an LLC in {state.name}</h1>
      <p class="llc-section-copy text-slate-600">{introCopy}</p>
    </div>

    <div class="llc-card-highlight space-y-5 !rounded-[1.5rem] !p-6 sm:!p-8">
      <div class="space-y-3">
        <p class="llc-helper">{topRecommendationEyebrow}</p>
        <h2>{topRecommendationTitle}</h2>
        <p class="llc-section-copy text-slate-700">{topRecommendationCopy}</p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {
          topRecommendationDetails.map((item) => (
            <div class="space-y-2 rounded-[1rem] border border-slate-200 bg-white/80 p-4">
              <p class="llc-helper text-slate-500">{item.label}</p>
              <p class="text-[15px] leading-7 text-slate-700">{item.description}</p>
            </div>
          ))
        }
      </div>

      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href={topRecommendationPrimaryHref}
          target={hasOfficialAgencyLink ? '_blank' : undefined}
          rel={hasOfficialAgencyLink ? 'noopener noreferrer' : undefined}
          class="inline-flex min-h-11 items-center justify-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
        >
          {topRecommendationPrimaryLabel}
        </a>
        <a
          href="/best-llc-services"
          class="inline-flex min-h-11 items-center justify-center rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-white"
        >
          Compare LLC services
        </a>
      </div>
    </div>

    <div id="state-guide-basics" class="llc-card-subtle !p-6 sm:!p-8">
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="llc-card flex min-h-40 flex-col justify-between">
          <p class="llc-helper">Filing fee</p>
          <div class="mt-6 space-y-3">
            <p class="text-[30px] font-semibold leading-none tracking-tight text-slate-950">{formatCurrency(state.filingFee)}</p>
            <p class="text-[14px] leading-6 text-slate-500">{filingFeeNote}</p>
          </div>
        </div>
        <div class="llc-card flex min-h-40 flex-col justify-between">
          <p class="llc-helper">Processing time</p>
          <div class="mt-6 space-y-3">
            <p class="text-[30px] font-semibold leading-none tracking-tight text-slate-950">{filingTimeValue}</p>
            <p class="text-[14px] leading-6 text-slate-500">{filingTimeNote}</p>
          </div>
        </div>
        <div class="llc-card flex min-h-40 flex-col justify-between">
          <p class="llc-helper">Annual report</p>
          <div class="mt-6 space-y-3">
            <p class="text-[30px] font-semibold leading-none tracking-tight text-slate-950">{annualReportValue}</p>
            <p class="text-[14px] leading-6 text-slate-500">{annualReportNote}</p>
          </div>
        </div>
        <div class="llc-card flex min-h-40 flex-col justify-between">
          <p class="llc-helper">Publication</p>
          <div class="mt-6 space-y-3">
            <p class="text-[30px] font-semibold leading-none tracking-tight text-slate-950">{publicationValue}</p>
            <p class="text-[14px] leading-6 text-slate-500">{publicationNote}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {
    officialLinks.length > 0 && (
      <section class="space-y-5">
        <h2>Official {state.name} resources</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {officialLinks.map((resource, index) => (
            <a
              href={resource.url}
              target="_blank"
              rel="noopener noreferrer"
              class={[
                index === 0
                  ? 'llc-card-highlight group transition hover:border-amber-400 hover:bg-[var(--bg-highlight)]'
                  : 'llc-card group bg-[var(--bg-subtle)] transition hover:border-slate-300 hover:bg-white',
              ].join(' ')}
            >
              <div class="flex items-center justify-between gap-3">
                <p class="llc-helper">Official source</p>
                {index === 0 && <span class="rounded-full bg-amber-200 px-2 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-amber-900 whitespace-nowrap">Start here</span>}
              </div>
              <p class="mt-3 text-lg font-semibold text-slate-950">{resource.label}</p>
              <p class="mt-2 text-[14px] leading-6 text-slate-600">Open the primary source for this step.</p>
              <div class="mt-4 flex items-center justify-between gap-4">
                <p class="break-all text-[13px] leading-5 text-slate-500">{resource.url}</p>
                <span class="shrink-0 text-sm font-semibold text-slate-400 transition group-hover:text-slate-700">Open</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <section class="space-y-5">
    <div class="space-y-4">
      <h2>How to form an LLC in {state.name}</h2>
      <p class="llc-section-copy">
        {hasDetailedSteps
          ? `These are the core steps most founders will work through when forming an LLC in ${state.name}.`
          : `We are still verifying the full step-by-step process for ${state.name}. Start with the confirmed state filing details and official resources before you submit anything.`}
      </p>
    </div>

    <div class="llc-card-highlight">
      <h3>What you'll need</h3>
      <p class="mt-3 llc-section-copy">{whatYoullNeedCopy}</p>
    </div>

    {
      hasDetailedSteps ? (
        <ol class="space-y-5">
          {
            state.steps.map((step, index) => (
              <li class="llc-card">
                <p class="llc-helper">Step {index + 1}</p>
                <h3 class="mt-3">{step.title}</h3>
                <p class="mt-3 llc-section-copy">{step.description}</p>
              </li>
            ))
          }
        </ol>
      ) : (
        <div class="llc-card">
          <p class="llc-section-copy text-slate-700">
            The full filing walkthrough for {state.name} is still being finalized. For now, confirm
            the filing fee, filing agency, processing timeline, and any annual requirements before
            you submit the paperwork yourself.
          </p>
        </div>
      )
    }
  </section>

  <section class="space-y-5">
    <div class="space-y-4">
      <h2>{state.name} LLC cost breakdown</h2>
      <p class="llc-section-copy">
        Use this table to see the upfront cost, the likely add-ons, and where the total can climb
        once you move past the bare filing fee.
      </p>
    </div>

    <div class="llc-card overflow-hidden !p-0">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="llc-table-head px-5 py-4 text-left">Item</th>
            <th class="llc-table-head px-5 py-4 text-right">Cost</th>
            {hasCostMeta && <th class="llc-table-head px-5 py-4 text-left">Required?</th>}
            {hasCostMeta && <th class="llc-table-head hidden px-5 py-4 text-left lg:table-cell">Notes</th>}
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          {
            costBreakdown.map((row) => (
              <tr class={row.isEmphasized ? 'bg-[var(--bg-highlight)]' : undefined}>
                <td class={['px-5 py-4', row.isEmphasized ? 'font-semibold text-slate-950' : 'text-slate-700'].join(' ')}>
                  {row.item}
                </td>
                <td class={['px-5 py-4 text-right', row.isEmphasized ? 'font-semibold text-slate-950' : 'text-slate-600'].join(' ')}>
                  {row.cost}
                </td>
                {hasCostMeta && (
                  <td class="px-5 py-4 text-slate-600">{row.required ?? '—'}</td>
                )}
                {hasCostMeta && (
                  <td class="hidden px-5 py-4 text-slate-600 lg:table-cell">{row.notes ?? '—'}</td>
                )}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  {
    taxHighlights.length > 0 && (
      <section class="space-y-5">
        <div class="space-y-4">
          <h2>{state.name} tax and compliance notes</h2>
          <p class="llc-section-copy">
            This is where {state.name} gets less simple than the filing itself. These are the
            state-specific issues that generic LLC guides usually gloss over.
          </p>
        </div>

        <div class="space-y-5">
          {taxHighlights.map((item) => (
            <div class="llc-card-subtle">
              <p class="llc-section-copy">{item}</p>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    comparisonRows.length > 0 && (
      <section class="space-y-5">
        <div class="space-y-4">
          <h2>{state.name} vs other LLC states</h2>
          <p class="llc-section-copy">
            This is the simple comparison most founders actually want. Keep an eye on the ongoing
            state cost column — that is where states with cheap filing fees can still get expensive.
          </p>
        </div>

        <div class="llc-card overflow-hidden !p-0">
          <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
              <tr>
                <th class="llc-table-head px-5 py-4 text-left">State</th>
                <th class="llc-table-head px-5 py-4 text-left">Annual report</th>
                <th class="llc-table-head px-5 py-4 text-right">Upfront cost</th>
                <th class="llc-table-head px-5 py-4 text-right">Ongoing state cost</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white">
              {comparisonRows.map((row) => (
                <tr class={row.state === state.name ? 'bg-[var(--bg-highlight)]' : undefined}>
                  <td class="px-5 py-4 font-semibold text-slate-950">
                    <div class="flex items-center gap-3">
                      <span>{row.state}</span>
                      {row.state === state.name && <span class="rounded-full bg-amber-200 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.06em] text-amber-900 whitespace-nowrap">This page</span>}
                    </div>
                  </td>
                  <td class="px-5 py-4 text-slate-700">{row.annualReport}</td>
                  <td class="px-5 py-4 text-right text-slate-700">{row.upfrontCost}</td>
                  <td class="px-5 py-4 text-right text-slate-700">{row.ongoingStateCost}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )
  }

  {
    hasProsCons && (
      <section class="space-y-5">
        <div class="space-y-4">
          <h2>{state.name} LLC pros and cons</h2>
          <p class="llc-section-copy">
            This is the quick tradeoff view: where {state.name} helps, where it adds friction, and
            what first-time founders should watch before they file.
          </p>
        </div>

        <div class="grid items-stretch gap-5 md:grid-cols-2">
          <div class="llc-card h-full border-slate-300">
            <div class="flex items-center gap-3">
              <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-amber-100 text-sm font-semibold text-amber-900">+</span>
              <h3>Pros</h3>
            </div>
            <ul class="mt-4 text-slate-700">
              {state.proscons.pros.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="llc-card h-full border-rose-200">
            <div class="flex items-center gap-3">
              <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-rose-100 text-sm font-semibold text-rose-700">-</span>
              <h3>Cons</h3>
            </div>
            <ul class="mt-4 text-slate-700">
              {state.proscons.cons.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </section>
    )
  }

  {
    hasFaqItems && (
      <section class="space-y-5">
        <div class="space-y-4">
          <h2>FAQ</h2>
          <p class="llc-section-copy">
            These are the questions people usually ask right before deciding whether to file on
            their own or pay a service.
          </p>
        </div>

        <div class="space-y-5">
          {
            faqItems.map((item) => (
              <details class="group llc-card !p-0">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-4 px-5 py-5 pr-5 text-lg font-semibold text-slate-950 marker:hidden sm:px-6">
                  <span>{item.question}</span>
                  <span class="mt-1 text-slate-400 transition group-open:rotate-180">⌄</span>
                </summary>
                <div class="border-t border-slate-200 px-5 py-5 sm:px-6">
                  <p class="llc-section-copy text-slate-600">{item.answer}</p>
                </div>
              </details>
            ))
          }
        </div>
      </section>
    )
  }

  <div slot="sidebar" class="space-y-4">
    <div class="llc-card-subtle">
      <p class="llc-helper">Safest paid option</p>
      <h2 class="mt-3 text-xl">Want help filing instead of doing it yourself?</h2>
      <p class="mt-3 text-[15px] leading-7 text-slate-700">
        {isResearchPending
          ? `If you want help with your ${state.name} filing, compare the main LLC services before you pay for anything extra. Start with the safest default, then compare the cheaper viable option.`
          : `${state.sidebarCtaDescription} Start with the safest default, then compare the cheaper viable option only if price is your main filter.`}
      </p>
      <a
        href="/best-llc-services"
        class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
      >
        Compare LLC services
      </a>
    </div>
  </div>
</SiteLayout>
