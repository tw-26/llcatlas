---
import { states, type StateData } from '../data/states';

interface Props {
  items?: StateData[];
}

const { items = states } = Astro.props as Props;

const stateItems = [...items].sort((left, right) => {
  if (left.contentStatus !== right.contentStatus) {
    return left.contentStatus === 'ready' ? -1 : 1;
  }

  return left.name.localeCompare(right.name);
});
const readyStates = stateItems.filter((state) => state.contentStatus === 'ready');
const comingSoonStates = stateItems.filter((state) => state.contentStatus !== 'ready');

const getFeeLabel = (state: StateData) =>
  state.filingFee > 0 ? `$${state.filingFee} filing fee` : null;
---

<div data-state-selector class="overflow-hidden rounded-[1.5rem] border border-rule bg-surface">
  <div class="border-b border-rule px-4 py-4 sm:px-5">
    <label for="state-search" class="mb-2 block text-[15px] font-medium text-ink-soft">
      Search by state name or abbreviation
    </label>
    <input
      id="state-search"
      type="search"
      placeholder="Type a state or abbreviation"
      autocomplete="off"
      spellcheck="false"
      data-state-search
      class="w-full rounded-2xl border border-rule-strong bg-surface px-4 py-3 text-lg text-ink-strong transition placeholder:text-ink-muted focus:border-accent"
    />
  </div>

  <div data-state-ready-block>
    <div class="border-b border-rule bg-surface-subtle px-4 py-3 sm:px-5">
      <p class="llc-helper">Available now</p>
      <p class="mt-2 text-[15px] leading-7 text-ink-soft">
        Guides with verified filing details and full walkthroughs.
      </p>
    </div>

    <ul data-state-section="ready" class="max-h-[28rem] divide-y divide-rule overflow-y-auto">
      {
        readyStates.map((state) => (
          <li
            data-state-card
            data-state-group="ready"
            data-state-name={state.name.toLowerCase()}
            data-state-abbreviation={state.abbreviation.toLowerCase()}
            class="px-4 py-4 sm:px-5"
          >
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div class="min-w-0">
                <p class="text-lg font-semibold text-ink-strong">{state.name}</p>
                <p class="text-[15px] leading-7 text-ink-soft">
                  {state.abbreviation}
                  {getFeeLabel(state) && ` · ${getFeeLabel(state)}`}
                </p>
              </div>

              <a
                href={`/llc/${state.slug}/`}
                class="inline-flex min-h-11 items-center text-[15px] font-semibold text-accent-ink underline decoration-accent/40 underline-offset-4 transition hover:decoration-accent-ink"
              >
                Read guide <span aria-hidden="true" class="ml-1">→</span>
              </a>
            </div>
          </li>
        ))
      }
    </ul>
  </div>

  {
    comingSoonStates.length > 0 && (
      <details data-state-coming-soon class="group border-t border-rule">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-4 text-[15px] font-semibold text-ink-strong marker:hidden sm:px-5">
          <span>Other states coming soon ({comingSoonStates.length})</span>
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4 text-ink-muted transition-transform duration-200 group-open:rotate-180"
          >
            <path d="M5 8l5 5 5-5" />
          </svg>
        </summary>

        <div class="border-t border-rule bg-surface-subtle px-4 py-4 sm:px-5">
          <p class="text-[15px] leading-7 text-ink-soft">
            We haven't finished writing these yet. Most LLC filings share the same five steps —
            while we publish, see our{' '}
            <a
              href="/best-llc-services/"
              class="font-semibold text-ink-strong underline decoration-rule-strong underline-offset-4 transition hover:text-ink-soft hover:decoration-ink-muted"
            >
              comparison of LLC services
            </a>{' '}
            for the cleanest way to file in any state.
          </p>
        </div>

        <ul data-state-section="coming-soon" class="divide-y divide-rule border-t border-rule">
          {
            comingSoonStates.map((state) => (
              <li
                data-state-card
                data-state-group="coming-soon"
                data-state-name={state.name.toLowerCase()}
                data-state-abbreviation={state.abbreviation.toLowerCase()}
                class="px-4 py-4 sm:px-5"
              >
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div class="min-w-0">
                    <p class="text-lg font-semibold text-ink-strong">{state.name}</p>
                    <p class="text-[15px] leading-7 text-ink-soft">{state.abbreviation}</p>
                  </div>

                  <span class="text-[15px] font-medium text-ink-muted">Guide in progress</span>
                </div>
              </li>
            ))
          }
        </ul>
      </details>
    )
  }

  <p hidden data-state-empty aria-live="polite" class="border-t border-rule px-4 py-4 text-[15px] text-ink-soft sm:px-5">
    No match. Try the full state name or its abbreviation.
  </p>
</div>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-state-selector]');

    if (!(root instanceof HTMLElement)) {
      return;
    }

    const input = root.querySelector('[data-state-search]');
    const emptyState = root.querySelector('[data-state-empty]');
    const readyBlock = root.querySelector('[data-state-ready-block]');
    const comingSoon = root.querySelector('[data-state-coming-soon]');
    const cards = Array.from(root.querySelectorAll('[data-state-card]'));

    if (
      !(input instanceof HTMLInputElement) ||
      !(emptyState instanceof HTMLElement) ||
      !(readyBlock instanceof HTMLElement)
    ) {
      return;
    }

    const applyFilter = () => {
      const query = input.value.trim().toLowerCase();
      let visibleCount = 0;
      let readyVisibleCount = 0;
      let comingSoonVisibleCount = 0;

      cards.forEach((card) => {
        if (!(card instanceof HTMLElement)) {
          return;
        }

        const stateName = card.dataset.stateName ?? '';
        const stateAbbreviation = card.dataset.stateAbbreviation ?? '';
        const matches =
          query.length === 0 || stateName.includes(query) || stateAbbreviation.includes(query);

        card.hidden = !matches;

        if (matches) {
          visibleCount += 1;

          if (card.dataset.stateGroup === 'coming-soon') {
            comingSoonVisibleCount += 1;
          } else {
            readyVisibleCount += 1;
          }
        }
      });

      readyBlock.hidden = readyVisibleCount === 0;
      emptyState.hidden = visibleCount > 0;

      if (comingSoon instanceof HTMLDetailsElement) {
        comingSoon.hidden = comingSoonVisibleCount === 0;
        comingSoon.open = query.length > 0 && comingSoonVisibleCount > 0;

        if (query.length === 0) {
          comingSoon.open = false;
        }
      }
    };

    input.addEventListener('input', applyFilter);
    input.addEventListener('search', applyFilter);
  })();
</script>
