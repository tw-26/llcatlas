---
interface Props {
  partnerName: string;
  href: string;
  stateName: string;
  placement?: 'sidebar' | 'inline';
  eyebrow?: string;
  heading?: string;
  description?: string;
  buttonLabel?: string;
  benefits?: string[];
  ctaNote?: string;
}

const {
  partnerName,
  href,
  stateName,
  placement = 'sidebar',
  eyebrow = 'Recommended partner',
  heading,
  description,
  buttonLabel,
  benefits,
  ctaNote,
} = Astro.props;

const isSidebar = placement === 'sidebar';

const resolvedHeading = heading
  ?? (isSidebar
    ? `${partnerName} for ${stateName}`
    : `Our pick for ${stateName}: ${partnerName}`);

const resolvedDescription = description
  ?? (isSidebar
    ? `Acts as your registered agent so your home address stays off the public ${stateName} filing.`
    : `We point most first-time ${stateName} founders to ${partnerName}. They keep your home address off the public record and don't push upsells at checkout.`);

const resolvedButtonLabel = buttonLabel
  ?? (isSidebar ? `Visit ${partnerName}` : `Start with ${partnerName}`);

const resolvedBenefits = !isSidebar && (!benefits || benefits.length === 0)
  ? [
      `Acts as your registered agent — keeps your home address off the public ${stateName} filing`,
      'No upsells or surprise fees at checkout',
      'First year of registered agent service included',
    ]
  : benefits ?? [];

const resolvedCtaNote = !isSidebar
  ? ctaNote ?? `Set up your ${stateName} LLC with hands-on help.`
  : null;

const isPlaceholderLink = !href || href === '#';
---

{isSidebar ? (
  <aside class="llc-card-cta" aria-label={`${eyebrow}: ${partnerName}`}>
    <p class="llc-helper">{eyebrow}</p>
    <h3 class="mt-3 text-[1.0625rem] leading-snug">{resolvedHeading}</h3>
    <p class="mt-3 text-[14px] leading-6 text-ink-soft">{resolvedDescription}</p>

    <a
      href={href}
      target="_blank"
      rel="sponsored noopener noreferrer"
      aria-disabled={isPlaceholderLink ? 'true' : undefined}
      data-affiliate-click={isPlaceholderLink ? undefined : ''}
      data-event-name="affiliate_click"
      data-partner={partnerName}
      data-placement={placement}
      data-state={stateName}
      class="mt-6 inline-flex min-h-11 w-full items-center justify-center rounded-full bg-accent px-5 py-3 text-center text-sm font-semibold text-ink-strong transition hover:bg-accent/85"
    >
      {resolvedButtonLabel}
    </a>

    <p class="mt-3 text-[12px] leading-5 text-ink-muted">
      Affiliate link &mdash; LLCAtlas may earn a commission.
    </p>
  </aside>
) : (
  <aside
    class="llc-card-cta !rounded-[20px] !p-6 sm:!p-8 lg:!p-9"
    aria-label={`${eyebrow}: ${partnerName}`}
  >
    <div class="grid gap-8 md:grid-cols-[minmax(0,1.35fr)_minmax(0,1fr)] md:items-stretch md:gap-x-8 lg:gap-x-10">
      <div class="flex min-w-0 flex-col">
        <span class="inline-flex w-fit items-center gap-2 rounded-full bg-accent-soft px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-accent-ink">
          <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          {eyebrow}
        </span>

        <h3 class="mt-4 text-xl leading-snug text-ink-strong sm:text-[1.375rem]">
          {resolvedHeading}
        </h3>

        <p class="mt-3 max-w-[52ch] text-[15px] leading-7 text-ink-soft">
          {resolvedDescription}
        </p>

        {resolvedBenefits.length > 0 && (
          <ul class="mt-5 space-y-2.5">
            {resolvedBenefits.map((benefit) => (
              <li class="flex items-start gap-2.5 text-[14px] leading-6 text-ink-soft">
                <span
                  aria-hidden="true"
                  class="mt-0.5 inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-accent-soft text-accent-ink"
                >
                  <svg
                    viewBox="0 0 12 12"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.25"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-2.5 w-2.5"
                  >
                    <path d="M2.5 6.5l2.25 2.25L9.5 3.75" />
                  </svg>
                </span>
                <span>{benefit}</span>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="flex min-w-0 flex-col rounded-[16px] border border-accent-soft bg-surface p-5 shadow-[0_1px_2px_rgba(15,23,42,0.04)] sm:p-6">
        <p class="llc-helper text-accent-ink">Get started</p>
        {resolvedCtaNote && (
          <p class="mt-2 text-[14px] leading-6 text-ink-soft">{resolvedCtaNote}</p>
        )}

        <a
          href={href}
          target="_blank"
          rel="sponsored noopener noreferrer"
          aria-disabled={isPlaceholderLink ? 'true' : undefined}
          data-affiliate-click={isPlaceholderLink ? undefined : ''}
          data-event-name="affiliate_click"
          data-partner={partnerName}
          data-placement={placement}
          data-state={stateName}
          class="group mt-5 inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-full bg-accent px-5 py-3 text-center text-sm font-semibold text-ink-strong transition hover:bg-accent/85 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
        >
          <span>{resolvedButtonLabel}</span>
          <svg
            aria-hidden="true"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5"
          >
            <path d="M3 8h10M9 4l4 4-4 4" />
          </svg>
        </a>

        <div class="mt-4 flex items-start gap-2 text-[12px] leading-5 text-ink-muted">
          <svg
            aria-hidden="true"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mt-0.5 h-3.5 w-3.5 shrink-0"
          >
            <path d="M8 1.5v3M8 11.5v3M1.5 8h3M11.5 8h3" />
            <circle cx="8" cy="8" r="2.25" />
          </svg>
          <span>Affiliate link &mdash; LLCAtlas may earn a commission at no extra cost to you.</span>
        </div>
      </div>
    </div>
  </aside>
)}
