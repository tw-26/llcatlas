---
interface Props {
  partnerName: string;
  href: string;
  stateName: string;
  placement?: 'sidebar' | 'inline';
  eyebrow?: string;
  heading?: string;
  description?: string;
  buttonLabel?: string;
}

const {
  partnerName,
  href,
  stateName,
  placement = 'sidebar',
  eyebrow = 'Recommended partner',
  heading = `Use ${partnerName} for your ${stateName} LLC`,
  description = 'This placeholder CTA is where your single, opinionated recommendation will live.',
  buttonLabel = `Start with ${partnerName}`,
} = Astro.props;

const isSidebar = placement === 'sidebar';
---

<div class={isSidebar ? 'llc-card-cta' : 'llc-card-cta'}>
  <p class="llc-helper">{eyebrow}</p>
  <h2 class={['mt-3', isSidebar ? 'text-xl' : 'text-2xl'].join(' ')}>{heading}</h2>
  <p class={['mt-3', isSidebar ? 'text-[15px] leading-7 max-w-none' : 'llc-section-copy'].join(' ')}>
    {description}
  </p>

  <ul class={['mt-5 text-[15px] text-slate-700', isSidebar ? 'space-y-2' : 'space-y-3'].join(' ')}>
    <li>Compare cost, privacy, and support quality.</li>
    <li>Best fit if you do not want your own address on the filing.</li>
    {!isSidebar && <li>Recheck live pricing before publishing because provider offers change.</li>}
  </ul>

  <a
    href={href}
    target="_blank"
    rel="sponsored noopener noreferrer"
    data-affiliate-click
    data-event-name="affiliate_click"
    data-partner={partnerName}
    data-placement={placement}
    data-state={stateName}
    class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-amber-500 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-amber-400"
  >
    {buttonLabel}
  </a>

  <p class="mt-3 text-[13px] leading-5 text-slate-500">
    Affiliate disclosure: LLCAtlas may earn a commission if you purchase after clicking this link.
  </p>
</div>

<script is:inline>
  if (!window.__llcAtlasAffiliateTrackingBound) {
    window.__llcAtlasAffiliateTrackingBound = true;

    document.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target.closest('[data-affiliate-click]') : null;

      if (!(target instanceof HTMLAnchorElement)) {
        return;
      }

      const eventName = target.dataset.eventName || 'affiliate_click';
      const payload = {
        partner: target.dataset.partner,
        placement: target.dataset.placement,
        state: target.dataset.state,
      };

      window.plausible?.(eventName, { props: payload });
      window.gtag?.('event', eventName, payload);
    });
  }
</script>
