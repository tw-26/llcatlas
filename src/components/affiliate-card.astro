---
interface Props {
  partnerName: string;
  href: string;
  stateName: string;
  placement?: 'sidebar' | 'inline';
  eyebrow?: string;
  heading?: string;
  description?: string;
  buttonLabel?: string;
}

const {
  partnerName,
  href,
  stateName,
  placement = 'sidebar',
  eyebrow = 'Recommended partner',
  heading,
  description,
  buttonLabel,
} = Astro.props;

const isSidebar = placement === 'sidebar';

const resolvedHeading = heading
  ?? (isSidebar
    ? `${partnerName} for ${stateName}`
    : `Our pick for ${stateName}: ${partnerName}`);

const resolvedDescription = description
  ?? (isSidebar
    ? `Acts as your registered agent so your home address stays off the public ${stateName} filing.`
    : `${partnerName} is the service we point most first-time ${stateName} founders to. They keep your home address off the public record and do not push aggressive upsells at checkout.`);

const resolvedButtonLabel = buttonLabel
  ?? (isSidebar ? `Visit ${partnerName}` : `Start with ${partnerName}`);

const isPlaceholderLink = !href || href === '#';
---

<aside class="llc-card-cta" aria-label={`${eyebrow}: ${partnerName}`}>
  <p class="llc-helper">{eyebrow}</p>
  <h3
    class={[
      'mt-3 leading-snug',
      isSidebar ? 'text-[1.0625rem]' : 'text-xl',
    ].join(' ')}
  >
    {resolvedHeading}
  </h3>
  <p
    class={[
      'mt-3 text-ink-soft',
      isSidebar
        ? 'text-[14px] leading-6 max-w-none'
        : 'text-[15px] leading-7 max-w-[60ch]',
    ].join(' ')}
  >
    {resolvedDescription}
  </p>

  <a
    href={href}
    target="_blank"
    rel="sponsored noopener noreferrer"
    aria-disabled={isPlaceholderLink ? 'true' : undefined}
    data-affiliate-click={isPlaceholderLink ? undefined : ''}
    data-event-name="affiliate_click"
    data-partner={partnerName}
    data-placement={placement}
    data-state={stateName}
    class="mt-6 inline-flex min-h-11 w-full items-center justify-center rounded-full bg-accent px-5 py-3 text-center text-sm font-semibold text-ink-strong transition hover:bg-accent/85"
  >
    {resolvedButtonLabel}
  </a>

  <p class="mt-3 text-[12px] leading-5 text-ink-muted">
    Affiliate link &mdash; LLCAtlas may earn a commission.
  </p>
</aside>

<script is:inline>
  if (!window.__llcAtlasAffiliateTrackingBound) {
    window.__llcAtlasAffiliateTrackingBound = true;

    document.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target.closest('[data-affiliate-click]') : null;

      if (!(target instanceof HTMLAnchorElement)) {
        return;
      }

      const eventName = target.dataset.eventName || 'affiliate_click';
      const payload = {
        partner: target.dataset.partner,
        placement: target.dataset.placement,
        state: target.dataset.state,
      };

      window.plausible?.(eventName, { props: payload });
      window.gtag?.('event', eventName, payload);
    });
  }
</script>
