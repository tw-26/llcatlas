---
import '../styles/global.css';
import atkinsonRegular from '@fontsource/atkinson-hyperlegible/files/atkinson-hyperlegible-latin-400-normal.woff2?url';

type StructuredData = Record<string, unknown>;

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  structuredData?: StructuredData | StructuredData[];
  noindex?: boolean;
}

const {
  title,
  description,
  ogType = 'website',
  structuredData = [],
  noindex = false,
} = Astro.props as Props;
const currentYear = new Date().getFullYear();
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const siteOrigin = siteUrl.toString().replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const logoUrl = new URL('/logo.svg', siteUrl).toString();
const currentPath = Astro.url.pathname;
const hasSidebar = Astro.slots.has('sidebar');
const isHomePage = currentPath === '/';
const isComparisonPage = currentPath === '/best-llc-services/' || currentPath === '/best-llc-services';
const isBestStatePage = currentPath === '/best-state/' || currentPath === '/best-state';
const isStateGuidePage = currentPath.startsWith('/llc/');
const homeLinkClass = isHomePage ? 'font-semibold text-ink-strong' : 'transition hover:text-ink-strong';
const stateLinkClass = isStateGuidePage ? 'font-semibold text-ink-strong' : 'transition hover:text-ink-strong';
const servicesLinkClass = isComparisonPage ? 'font-semibold text-ink-strong' : 'transition hover:text-ink-strong';
const bestStateLinkClass = isBestStatePage ? 'font-semibold text-ink-strong' : 'transition hover:text-ink-strong';
const primaryNavCta = isStateGuidePage
  ? { href: '/best-llc-services', label: 'Compare services' }
  : { href: '/#state-selector', label: 'Find your state' };
const contentWidthClass = isHomePage ? 'max-w-6xl' : 'max-w-5xl';
const pageStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const defaultStructuredData: StructuredData[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'LLCAtlas',
    url: siteOrigin,
    logo: logoUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'LLCAtlas',
    url: siteOrigin,
    inLanguage: 'en-US',
  },
];
const allStructuredData = [...defaultStructuredData, ...pageStructuredData];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={atkinsonRegular}
      crossorigin
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={
        noindex
          ? 'noindex, follow'
          : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'
      }
    />
    <meta property="og:site_name" content="LLCAtlas" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "9c94b268b27b4893a043076eae99ca12"}'
    ></script>
    {
      allStructuredData.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <div class="min-h-screen">
      <header class="border-b border-rule bg-surface">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-4 py-5 sm:px-6 lg:px-8">
          <a href="/" aria-label="LLCAtlas home" class="flex items-center">
            <img
              src="/logo.svg"
              alt="LLCAtlas"
              class="h-10 w-auto sm:h-11"
              width="300"
              height="56"
              loading="eager"
            />
          </a>

          <nav aria-label="Primary" class="hidden items-center gap-6 text-sm text-ink-soft md:flex">
            <a href="/" class={homeLinkClass} aria-current={isHomePage ? 'page' : undefined}>Home</a>
            <a
              href="/best-state"
              class={bestStateLinkClass}
              aria-current={isBestStatePage ? 'page' : undefined}
            >
              Best state
            </a>
            <a
              href="/best-llc-services"
              class={servicesLinkClass}
              aria-current={isComparisonPage ? 'page' : undefined}
            >
              Compare services
            </a>
            <a
              href={primaryNavCta.href}
              class="rounded-full bg-accent px-4 py-2 font-semibold text-ink-strong transition hover:bg-accent/85"
            >
              {primaryNavCta.label}
            </a>
          </nav>
        </div>

        <div class="border-t border-rule md:hidden">
          <div class="mx-auto flex max-w-7xl flex-wrap gap-3 px-4 py-3 sm:px-6">
            <a
              href="/best-state"
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-rule-strong px-4 py-2 text-sm font-semibold text-ink-strong transition hover:border-ink-muted hover:bg-surface-subtle"
              aria-current={isBestStatePage ? 'page' : undefined}
            >
              Best state
            </a>
            <a
              href="/best-llc-services"
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-rule-strong px-4 py-2 text-sm font-semibold text-ink-strong transition hover:border-ink-muted hover:bg-surface-subtle"
              aria-current={isComparisonPage ? 'page' : undefined}
            >
              Compare services
            </a>
            <a
              href={primaryNavCta.href}
              class="inline-flex min-h-11 items-center justify-center rounded-full bg-accent px-4 py-2 text-sm font-semibold text-ink-strong transition hover:bg-accent/85"
            >
              {primaryNavCta.label}
            </a>
          </div>
        </div>
      </header>

      <main id="main" tabindex="-1" class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
        {
          hasSidebar ? (
            <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-start">
              <article class="min-w-0 space-y-12">
                <slot />
              </article>

              <aside class="lg:sticky lg:top-10">
                <slot name="sidebar" />
              </aside>
            </div>
          ) : (
            <article class={['mx-auto min-w-0 space-y-12', contentWidthClass].join(' ')}>
              <slot />
            </article>
          )
        }
      </main>

      <script is:inline>
        if (!window.__llcAtlasAffiliateTrackingBound) {
          window.__llcAtlasAffiliateTrackingBound = true;

          document.addEventListener('click', (event) => {
            const target = event.target instanceof Element ? event.target.closest('[data-affiliate-click]') : null;

            if (!(target instanceof HTMLAnchorElement)) {
              return;
            }

            const eventName = target.dataset.eventName || 'affiliate_click';
            const payload = {
              partner: target.dataset.partner,
              placement: target.dataset.placement,
              state: target.dataset.state,
            };

            window.plausible?.(eventName, { props: payload });
          });
        }
      </script>

      <footer class="border-t border-rule bg-surface-subtle">
        <div class="mx-auto max-w-7xl space-y-4 px-4 py-8 sm:px-6 lg:px-8">
          <p class="text-sm font-semibold text-ink-strong">Affiliate disclosure</p>
          <p class="max-w-3xl text-sm text-ink-soft">
            LLCAtlas may earn a commission if you click a partner link and purchase a service.
            That does not change our editorial stance. We do not form LLCs, file paperwork, or
            provide legal or tax advice.
          </p>
          <p class="text-sm text-ink-muted">
            © {currentYear} LLCAtlas. Built for clear LLC decisions. ·{' '}
            <a
              href="/privacy"
              class="underline decoration-rule-strong underline-offset-4 transition hover:text-ink-soft hover:decoration-ink-muted"
            >
              Privacy
            </a>
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
