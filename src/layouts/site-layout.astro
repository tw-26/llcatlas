---
import '../styles/global.css';

type StructuredData = Record<string, unknown>;

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  structuredData?: StructuredData | StructuredData[];
}

const {
  title,
  description,
  ogType = 'website',
  structuredData = [],
} = Astro.props as Props;
const currentYear = new Date().getFullYear();
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const siteOrigin = siteUrl.toString().replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const logoUrl = new URL('/logo.svg', siteUrl).toString();
const currentPath = Astro.url.pathname;
const hasSidebar = Astro.slots.has('sidebar');
const isHomePage = currentPath === '/';
const isComparisonPage = currentPath === '/best-llc-services/' || currentPath === '/best-llc-services';
const isStateGuidePage = currentPath.startsWith('/llc/');
const homeLinkClass = isHomePage ? 'font-semibold text-slate-950' : 'transition hover:text-slate-950';
const stateLinkClass = isStateGuidePage ? 'font-semibold text-slate-950' : 'transition hover:text-slate-950';
const servicesLinkClass = isComparisonPage ? 'font-semibold text-slate-950' : 'transition hover:text-slate-950';
const primaryNavCta = isStateGuidePage
  ? { href: '/best-llc-services', label: 'Compare services' }
  : { href: '/#state-selector', label: 'Find your state' };
const contentWidthClass = isHomePage ? 'max-w-6xl' : 'max-w-5xl';
const pageStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const defaultStructuredData: StructuredData[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'LLCAtlas',
    url: siteOrigin,
    logo: logoUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'LLCAtlas',
    url: siteOrigin,
    inLanguage: 'en-US',
  },
];
const allStructuredData = [...defaultStructuredData, ...pageStructuredData];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta property="og:site_name" content="LLCAtlas" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2V8YRX5N8M"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-2V8YRX5N8M');
    </script>
    {
      allStructuredData.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
  </head>
  <body>
    <div class="min-h-screen">
      <header class="border-b border-slate-200 bg-white">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-4 py-5 sm:px-6 lg:px-8">
          <a href="/" aria-label="LLCAtlas home" class="flex items-center">
            <img
              src="/logo.svg"
              alt="LLCAtlas"
              class="h-10 w-auto sm:h-11"
              width="300"
              height="56"
              loading="eager"
            />
          </a>

          <nav aria-label="Primary" class="hidden items-center gap-6 text-sm text-slate-600 md:flex">
            <a href="/" class={homeLinkClass} aria-current={isHomePage ? 'page' : undefined}>Home</a>
            <a
              href="/#state-selector"
              class={stateLinkClass}
              aria-current={isStateGuidePage ? 'page' : undefined}
            >
              State guides
            </a>
            <a
              href="/best-llc-services"
              class={servicesLinkClass}
              aria-current={isComparisonPage ? 'page' : undefined}
            >
              Compare services
            </a>
            <a
              href={primaryNavCta.href}
              class="rounded-full bg-amber-500 px-4 py-2 font-semibold text-slate-950 transition hover:bg-amber-400"
            >
              {primaryNavCta.label}
            </a>
          </nav>
        </div>

        <div class="border-t border-slate-200 md:hidden">
          <div class="mx-auto flex max-w-7xl flex-wrap gap-3 px-4 py-3 sm:px-6">
            <a
              href="/#state-selector"
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-slate-50"
            >
              Find your state
            </a>
            <a
              href="/best-llc-services"
              class="inline-flex min-h-11 items-center justify-center rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800"
            >
              Compare services
            </a>
          </div>
        </div>
      </header>

      <main class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
        {
          hasSidebar ? (
            <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-start">
              <article class="min-w-0 space-y-10">
                <slot />
              </article>

              <aside class="lg:sticky lg:top-10">
                <slot name="sidebar" />
              </aside>
            </div>
          ) : (
            <article class={['mx-auto min-w-0 space-y-10', contentWidthClass].join(' ')}>
              <slot />
            </article>
          )
        }
      </main>

      <footer class="border-t border-slate-200 bg-slate-50">
        <div class="mx-auto max-w-7xl space-y-4 px-4 py-8 sm:px-6 lg:px-8">
          <p class="text-sm font-semibold text-slate-950">Affiliate disclosure</p>
          <p class="max-w-3xl text-sm text-slate-600">
            LLCAtlas may earn a commission if you click a partner link and purchase a service.
            That does not change our editorial stance. We do not form LLCs, file paperwork, or
            provide legal or tax advice.
          </p>
          <p class="text-sm text-slate-500">© {currentYear} LLCAtlas. Built for clear LLC decisions.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
