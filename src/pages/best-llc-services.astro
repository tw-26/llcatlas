  <div slot="sidebar" class="space-y-4">
    <AffiliateCard
      partnerName={defaultPick.name}
      href={defaultPick.affiliateUrl}
      stateName="LLC"
      placement="sidebar"
      eyebrow="Safest default"
      heading={`Start with ${defaultPick.name} if you want the cleanest paid option`}
      buttonLabel={`${defaultPick.ctaLabel} →`}
      description={`As of ${llcServicesLastUpdated}, ${defaultPick.name} is still the easiest service to recommend to first-time founders who want help, privacy, and fewer buying headaches.`}
    />

    <div class="llc-card-subtle">
      <p class="llc-helper">On this page</p>
      <ul class="mt-4 text-sm text-slate-700">
        <li><a href="#bizee">Bizee review</a></li>
        <li><a href="#northwest">Northwest review</a></li>
        <li><a href="#zenbusiness">ZenBusiness review</a></li>
        <li><a href="#legalzoom">LegalZoom review</a></li>
        <li><a href="#northwest-vs-zenbusiness">Northwest vs ZenBusiness</a></li>
        <li><a href="#bizee-vs-zenbusiness">Bizee vs ZenBusiness</a></li>
      </ul>
    </div>

    <div class="llc-card-subtle">
      <p class="llc-helper">Why this page matters</p>
      <p class="mt-3 text-sm leading-7 text-slate-600">
        If you already know your state rules but still want filing help, this page shows which
        services are worth paying for and which ones are not.
      </p>
    </div>
  </div>

  <script is:inline>
    const openTargetedDetails = () => {
      const hash = window.location.hash;

      if (!hash) {
        return;
      }

      const targetId = decodeURIComponent(hash.slice(1));
      const target = document.getElementById(targetId);
      const details = target instanceof HTMLDetailsElement ? target : target?.closest('details');

      if (details && !details.open) {
        details.open = true;
      }
    };

    openTargetedDetails();
    window.addEventListener('hashchange', openTargetedDetails);
  </script>
</SiteLayout>
