---
import AffiliateCard from '../components/affiliate-card.astro';
import SiteLayout from '../layouts/site-layout.astro';
import {
  featuredStateGuideSlugs,
  llcServices,
  llcServicesFaq,
  llcServicesLastUpdated,
  llcServiceMethodology,
  serviceComparisons,
} from '../data/llc-services';
import { states } from '../data/states';

const title = 'Best LLC Formation Services (2026) — Compared and Ranked | LLCAtlas';
const description =
  "We tested the top LLC services so you don't have to. Northwest, ZenBusiness, Bizee, and more — compared on price, speed, and what's actually included.";
const pageUrl = 'https://llcatlas.com/best-llc-services/';

const rankedServices = [...llcServices].sort((left, right) => left.realYearOneTotal - right.realYearOneTotal);
const defaultPick = rankedServices.find((service) => service.slug === 'northwest') ?? rankedServices[0];
const cheapestViablePick = rankedServices[0];
const avoidPick = rankedServices.find((service) => service.slug === 'legalzoom');
const featuredStateGuides = featuredStateGuideSlugs
  .map((slug) => states.find((state) => state.slug === slug))
  .filter(Boolean);
const comparisonSummaryRows = [
  {
    label: "What you'll actually pay year 1",
    getValue: (service) => service.realYearOneTotalLabel,
  },
  {
    label: 'Registered agent in year 1',
    getValue: (service) => service.registeredAgentLabel,
  },
  {
    label: 'Registered agent renewal',
    getValue: (service) => service.registeredAgentRenewalLabel,
  },
  {
    label: 'Upsell pressure',
    getValue: (service) => service.checkoutExperience,
  },
  {
    label: 'Best for',
    getValue: (service) => service.bestFor,
  },
] as const;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: pageUrl,
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Best LLC formation services ranking',
    itemListOrder: 'https://schema.org/ItemListOrderAscending',
    numberOfItems: rankedServices.length,
    itemListElement: rankedServices.map((service, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: service.name,
      url: `${pageUrl}#${service.slug}`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: llcServicesFaq.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: 'https://llcatlas.com/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Best LLC services',
        item: pageUrl,
      },
    ],
  },
];
---

<SiteLayout title={title} description={description} structuredData={structuredData}>
  <section class="space-y-8">
    <div class="space-y-4">
      <p class="llc-helper">Best LLC service comparison</p>
      <h1>Best LLC formation services in 2026</h1>
      <p class="max-w-3xl text-sm text-slate-500">
        LLCAtlas is reader-supported. When you buy through our links, we may earn a commission.
        This does not affect our rankings. We rank providers by real year-one cost, privacy,
        support, and how much nonsense they try to sell you during checkout.
      </p>
      <p class="llc-section-copy text-slate-600">
        We compared {rankedServices.length} LLC formation services using one framework: safest
        default first, cheaper viable option second, and the provider most first-time founders
        should avoid overpaying for. If you only read one section on this page, read the verdict
        and the quick comparison below.
      </p>
    </div>

    <div class="llc-card-highlight !p-6 sm:!p-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="space-y-3">
          <span class="inline-flex rounded-full bg-amber-200 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-amber-950">
            Safest default for most first-time founders
          </span>
          <div class="space-y-2">
            <h2>{defaultPick.name} — {defaultPick.headlinePriceLabel}</h2>
            <p class="llc-section-copy text-slate-700">
              Start here if you want the cleanest paid option, the strongest privacy-first pitch,
              and the least frustrating buying experience.
            </p>
          </div>
          <ul class="text-slate-700">
            {defaultPick.pros.slice(0, 3).map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <a
          href={defaultPick.affiliateUrl}
          target="_blank"
          rel="sponsored noopener noreferrer"
          data-affiliate-click
          data-event-name="affiliate_click"
          data-partner={defaultPick.name}
          data-placement="hero"
          data-state="national"
          class="inline-flex shrink-0 items-center justify-center rounded-full bg-amber-500 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-amber-400"
        >
          {defaultPick.ctaLabel} →
        </a>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      <section class="llc-card-subtle space-y-3">
        <p class="llc-helper">Cheaper viable option</p>
        <h2 class="text-xl">{cheapestViablePick.name}</h2>
        <p class="text-[15px] leading-7 text-slate-700">
          Choose this only if year-one cost is your main filter and you are comfortable with a
          rougher checkout experience.
        </p>
        <p class="text-sm font-semibold text-slate-950">
          Real year-one cost: {cheapestViablePick.realYearOneTotalLabel}
        </p>
      </section>

      <section class="llc-card-subtle space-y-3">
        <p class="llc-helper">How LLCAtlas recommends</p>
        <p class="text-[15px] leading-7 text-slate-700">
          We separate the safest default from the cheapest viable option. That keeps the decision
          honest for first-time founders who care about both cost and hassle.
        </p>
        <p class="text-[15px] leading-7 text-slate-700">
          If you want the strongest all-around answer, start with {defaultPick.name}. If you only
          care about the lowest usable year-one cost, check {cheapestViablePick.name} next. The
          provider to avoid overpaying for is {avoidPick?.name}.
        </p>
      </section>

      <section class="llc-card border-rose-200 bg-rose-50/50 space-y-3">
        <p class="llc-helper text-rose-700">Avoid overpaying</p>
        <h2 class="text-xl">Skip {avoidPick?.name} for most standard LLC filings</h2>
        <p class="text-[15px] leading-7 text-slate-700">
          {avoidPick?.name} is the familiar brand, but for most first-time founders the price
          premium is too hard to justify once you compare it against the default and budget picks.
        </p>
        <p class="text-sm font-semibold text-slate-950">
          Real year-one cost: {avoidPick?.realYearOneTotalLabel}
        </p>
      </section>
    </div>

    <div class="llc-card overflow-hidden !p-0">
      <div class="flex flex-col gap-3 border-b border-slate-200 bg-slate-50 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="llc-helper">Quick comparison</p>
          <p class="mt-1 text-sm text-slate-600">
            The column that matters most is what you will actually pay in year one before the state
            fee. Use this table to compare the default pick against the cheaper viable option and
            the provider we would avoid overpaying for.
          </p>
        </div>
        <span class="inline-flex rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-amber-900">
          Last updated: {llcServicesLastUpdated}
        </span>
      </div>

      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="llc-table-head px-5 py-4 text-left">Service</th>
            <th class="llc-table-head px-5 py-4 text-left">Advertised price</th>
            <th class="llc-table-head px-5 py-4 text-left">What you will actually pay year 1</th>
            <th class="llc-table-head px-5 py-4 text-left">Registered agent</th>
            <th class="llc-table-head px-5 py-4 text-left">Upsells</th>
            <th class="llc-table-head px-5 py-4 text-left">Our verdict</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          {
            rankedServices.map((service, index) => (
              <tr class={index === 0 ? 'bg-[var(--bg-highlight)]' : undefined}>
                <td class="px-5 py-4">
                  <div class="flex items-center gap-3">
                    <a href={`#${service.slug}`} class="font-semibold text-slate-950 hover:text-slate-700">
                      {service.name}
                    </a>
                    {index === 0 && (
                      <span class="rounded-full bg-amber-200 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-amber-900 whitespace-nowrap">
                        #1
                      </span>
                    )}
                  </div>
                </td>
                <td class="px-5 py-4 text-slate-700">{service.headlinePriceLabel}</td>
                <td class="px-5 py-4 font-semibold text-slate-950">{service.realYearOneTotalLabel}</td>
                <td class="px-5 py-4 text-slate-700">{service.registeredAgentLabel}</td>
                <td class="px-5 py-4 text-slate-700">{service.checkoutExperience}</td>
                <td class="px-5 py-4 text-slate-700">{service.tableVerdict}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="space-y-5">
    <div class="space-y-3">
      <h2>How we score LLC services</h2>
      <p class="llc-section-copy text-slate-600">
        Most people can skip this. Expand it only if you want to see the exact rules behind the
        rankings.
      </p>
    </div>

    <details class="group llc-card-subtle overflow-hidden !p-0">
      <summary class="flex cursor-pointer list-none items-start justify-between gap-4 px-5 py-5 text-lg font-semibold text-slate-950 transition-colors hover:bg-slate-50/70 marker:hidden sm:px-6">
        <span>Show methodology</span>
        <span class="mt-1 text-slate-400 transition group-open:rotate-180">⌄</span>
      </summary>
      <div class="border-t border-slate-200 px-5 py-5 sm:px-6">
        <ul class="text-slate-700">
          {llcServiceMethodology.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </details>
  </section>

  <section class="space-y-6">
    <div class="space-y-3">
      <h2>Full reviews if you want the details</h2>
      <p class="llc-section-copy text-slate-600">
        The answer is already above. Use these only if you want the longer breakdown on checkout
        friction, upsells, support, and privacy.
      </p>
    </div>

    <div class="space-y-8">
      {
        rankedServices.map((service, index) => (
          <details id={service.slug} class="group llc-card overflow-hidden !p-0 scroll-mt-8">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 px-5 py-5 transition-colors hover:bg-slate-50/70 marker:hidden sm:px-6">
              <div class="space-y-3">
                <p class="llc-helper">Rank #{index + 1}</p>
                <h3>{service.name} — {service.oneLineVerdict}</h3>
                <p class="text-sm leading-7 text-slate-600">{service.rankingSummary}</p>
                <div class="flex flex-wrap gap-2 text-sm text-slate-600">
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1">
                    Year 1: {service.realYearOneTotalLabel}
                  </span>
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1">
                    Best for: {service.bestFor}
                  </span>
                </div>
              </div>
              <span class="mt-1 shrink-0 text-slate-400 transition group-open:rotate-180">⌄</span>
            </summary>

            <div class="border-t border-slate-200 px-5 py-6 sm:px-6">
              <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
                <div class="llc-card-subtle">
                  <p class="llc-helper">Price</p>
                  <p class="mt-3 text-lg font-semibold text-slate-950">{service.headlinePriceLabel}</p>
                </div>
                <div class="llc-card-subtle">
                  <p class="llc-helper">Registered agent</p>
                  <p class="mt-3 text-lg font-semibold text-slate-950">{service.registeredAgentLabel}</p>
                </div>
                <div class="llc-card-subtle">
                  <p class="llc-helper">Processing time</p>
                  <p class="mt-3 text-lg font-semibold text-slate-950">{service.processingTime}</p>
                </div>
                <div class="llc-card-subtle">
                  <p class="llc-helper">Best for</p>
                  <p class="mt-3 text-lg font-semibold text-slate-950">{service.bestFor}</p>
                </div>
                <div class="llc-card-subtle">
                  <p class="llc-helper">Renewal pricing</p>
                  <p class="mt-3 text-lg font-semibold text-slate-950">{service.registeredAgentRenewalLabel}</p>
                </div>
              </div>

              <div class="mt-5 grid gap-5 lg:grid-cols-2">
                <div class="llc-card-subtle">
                  <p class="llc-helper">What is included on the cheapest path</p>
                  <ul class="mt-4 text-slate-700">
                    <li>Formation filing: {service.includedFeatures.formationFiling}</li>
                    <li>Registered agent: {service.includedFeatures.registeredAgent}</li>
                    <li>Operating agreement: {service.includedFeatures.operatingAgreement}</li>
                    <li>EIN filing: {service.includedFeatures.ein}</li>
                  </ul>
                </div>

                <div class="llc-card-subtle">
                  <p class="llc-helper">What costs extra</p>
                  <ul class="mt-4 text-slate-700">
                    {service.commonUpsells.map((item) => (
                      <li>
                        <span class="font-semibold text-slate-950">{item.label}:</span> {item.cost}.{' '}
                        {item.notes}
                      </li>
                    ))}
                  </ul>
                  <p class="mt-4 text-sm font-semibold text-slate-950">
                    Real total cost year 1: {service.realYearOneTotalLabel}
                  </p>
                  <p class="mt-2 text-sm font-semibold text-slate-950">
                    Registered agent after year 1: {service.registeredAgentRenewalLabel}
                  </p>
                </div>
              </div>

              <div class="mt-5 grid gap-5 md:grid-cols-2">
                <div class="llc-card border-emerald-200">
                  <div class="flex items-center gap-3">
                    <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-emerald-100 text-sm font-semibold text-emerald-700">
                      +
                    </span>
                    <p class="text-base font-semibold text-slate-950">Pros</p>
                  </div>
                  <ul class="mt-4 text-slate-700">
                    {service.pros.map((item) => <li>{item}</li>)}
                  </ul>
                </div>

                <div class="llc-card border-rose-200">
                  <div class="flex items-center gap-3">
                    <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-rose-100 text-sm font-semibold text-rose-700">
                      -
                    </span>
                    <p class="text-base font-semibold text-slate-950">Cons</p>
                  </div>
                  <ul class="mt-4 text-slate-700">
                    {service.cons.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </div>

              <div class="mt-5 grid gap-5 lg:grid-cols-[minmax(0,1fr)_260px]">
                <div class="llc-card-highlight">
                  <p class="llc-helper">Our take</p>
                  <div class="mt-4 space-y-4">
                    {service.ourTake.map((paragraph) => (
                      <p class="llc-section-copy text-slate-700">{paragraph}</p>
                    ))}
                    <p class="llc-section-copy text-slate-700">
                      <span class="font-semibold text-slate-950">Privacy:</span> {service.privacyTake}
                    </p>
                    <p class="llc-section-copy text-slate-700">
                      <span class="font-semibold text-slate-950">Support:</span> {service.supportTake}
                    </p>
                    <p class="text-sm text-slate-500">{service.advertisedPriceNote}</p>
                  </div>
                </div>

                <div class="llc-card-cta">
                  <p class="llc-helper">Take action</p>
                  <p class="mt-3 text-lg font-semibold text-slate-950">{service.name}</p>
                  <p class="mt-3 text-sm leading-7 text-slate-600">
                    If this is your best fit, use the cheapest path that still covers the
                    registered agent if you want privacy.
                  </p>
                  <a
                    href={service.affiliateUrl}
                    target="_blank"
                    rel="sponsored noopener noreferrer"
                    data-affiliate-click
                    data-event-name="affiliate_click"
                    data-partner={service.name}
                    data-placement="review-bottom"
                    data-state="national"
                    class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-amber-500 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-amber-400"
                  >
                    {service.ctaLabel} →
                  </a>
                </div>
              </div>
            </div>
          </details>
        ))
      }
    </div>
  </section>

  <section class="space-y-6">
    <div class="space-y-3">
      <h2>Head-to-head comparisons</h2>
      <p class="llc-section-copy text-slate-600">
        Most people can skip these. Open the matchup you care about if you are deciding between two
        specific brands.
      </p>
    </div>

    <div class="space-y-6">
      {
        serviceComparisons.map((comparison) => {
          const leftService = rankedServices.find((service) => service.slug === comparison.providerSlugs[0]);
          const rightService = rankedServices.find((service) => service.slug === comparison.providerSlugs[1]);

          if (!leftService || !rightService) {
            return null;
          }

          return (
            <details id={comparison.id} class="group llc-card overflow-hidden !p-0 scroll-mt-8">
              <summary class="flex cursor-pointer list-none items-start justify-between gap-4 px-5 py-5 transition-colors hover:bg-slate-50/70 marker:hidden sm:px-6">
                <div class="space-y-2">
                  <h3>{comparison.title}</h3>
                  <p class="text-sm font-semibold text-slate-950">Winner: {comparison.winner}</p>
                </div>
                <span class="mt-1 shrink-0 text-slate-400 transition group-open:rotate-180">⌄</span>
              </summary>

              <div class="border-t border-slate-200 px-5 py-6 sm:px-6">
                <p class="text-sm text-slate-500">
                  Jump to the full reviews:{' '}
                  <a href={`#${leftService.slug}`} class="font-medium text-slate-700 hover:text-slate-950">
                    {leftService.name}
                  </a>{' '}
                  and{' '}
                  <a href={`#${rightService.slug}`} class="font-medium text-slate-700 hover:text-slate-950">
                    {rightService.name}
                  </a>
                </p>

                <div class="mt-4 llc-card-subtle overflow-hidden !p-0">
                  <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                      <tr>
                        <th class="llc-table-head px-5 py-4 text-left">Compare</th>
                        <th class="llc-table-head px-5 py-4 text-left">{leftService.name}</th>
                        <th class="llc-table-head px-5 py-4 text-left">{rightService.name}</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 bg-white">
                      {comparisonSummaryRows.map((row) => (
                        <tr>
                          <td class="px-5 py-4 font-semibold text-slate-950">{row.label}</td>
                          <td class="px-5 py-4 text-slate-700">{row.getValue(leftService)}</td>
                          <td class="px-5 py-4 text-slate-700">{row.getValue(rightService)}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>

                <div class="mt-4 space-y-4">
                  {comparison.paragraphs.map((paragraph) => (
                    <p class="llc-section-copy text-slate-700">{paragraph}</p>
                  ))}
                </div>
              </div>
            </details>
          );
        })
      }
    </div>
  </section>

  <section class="space-y-5">
    <div class="space-y-3">
      <h2>How to choose the right LLC service</h2>
      <p class="llc-section-copy text-slate-600">
        Match the provider to the framework below. Do not overcomplicate this.
      </p>
    </div>

    <div class="llc-card-subtle space-y-4">
      <div class="flex flex-col gap-2 border-b border-slate-200 pb-4 md:flex-row md:items-start md:justify-between">
        <p class="font-semibold text-slate-950">Safest default</p>
        <a href={`#${defaultPick.slug}`} class="text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500">
          → {defaultPick.name}
        </a>
      </div>
      <div class="flex flex-col gap-2 border-b border-slate-200 pb-4 md:flex-row md:items-start md:justify-between">
        <p class="font-semibold text-slate-950">Cheaper viable option</p>
        <p class="text-slate-700">
          <a href={`#${cheapestViablePick.slug}`} class="underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500">
            → {cheapestViablePick.name}
          </a>{' '}
          first,{' '}
          <a href="#zenbusiness" class="underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500">
            ZenBusiness
          </a>{' '}
          second
        </p>
      </div>
      <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
        <p class="font-semibold text-slate-950">Avoid overpaying</p>
        <a href={`#${avoidPick?.slug}`} class="text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500">
          → {avoidPick?.name} for most standard LLC filings
        </a>
      </div>
    </div>
  </section>

  <section class="llc-card-subtle space-y-5">
    <div class="space-y-3">
      <h2>What you do not need to buy</h2>
      <p class="llc-section-copy text-slate-600">
        This is where a lot of founders get nickeled and dimed. Most first-time owners can skip the
        routine add-ons below and do them themselves.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      <div class="llc-card bg-white">
        <p class="llc-helper">Skip the EIN upsell</p>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          The IRS gives you an EIN for free. Paying $79 to $99 for someone else to click through the
          form is usually wasted money.
        </p>
      </div>
      <div class="llc-card bg-white">
        <p class="llc-helper">Skip the operating agreement template upsell</p>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Most providers resell a template you can draft yourself or buy far more cheaply elsewhere.
          Useful document, bad place to buy it.
        </p>
      </div>
      <div class="llc-card bg-white">
        <p class="llc-helper">Skip paid compliance alerts if you are organized</p>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Annual reminders are helpful, but not worth $99 a year for many owners. A calendar and
          direct state notices cover the basics.
        </p>
      </div>
    </div>
  </section>

  <section class="llc-card-subtle space-y-5">
    <div class="space-y-3">
      <h2>State-specific LLC guides</h2>
      <p class="llc-section-copy text-slate-600">
        These providers work in all 50 states, but the filing fee, timeline, publication rules, and
        annual-report headaches still depend on where you form. Start with one of these guides if
        you want the state-level rules next.
      </p>
    </div>

    <div class="space-y-4">
      {featuredStateGuides[0] && (
        <a
          href={`/llc/${featuredStateGuides[0].slug}`}
          class="llc-card-highlight block transition hover:border-amber-400"
        >
          <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="llc-helper">Live now</p>
              <p class="mt-2 text-lg font-semibold text-slate-950">
                Start with the {featuredStateGuides[0].name} LLC guide
              </p>
              <p class="mt-2 text-sm leading-7 text-slate-600">
                If you want a live state-level example first, start with the {featuredStateGuides[0].name} guide.
              </p>
            </div>
            <span class="text-sm font-semibold text-slate-950">
              Read {featuredStateGuides[0].name} guide →
            </span>
          </div>
        </a>
      )}

      <div class="flex flex-wrap gap-3">
        {featuredStateGuides.slice(1).map((state) => (
          <a
            href={`/llc/${state.slug}`}
            class="inline-flex items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-slate-50"
          >
            {state.name} LLC guide
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="space-y-5">
    <div class="space-y-3">
      <h2>FAQ</h2>
      <p class="llc-section-copy text-slate-600">
        These are the questions that usually show up right before someone decides whether to file
        themselves or pay a service.
      </p>
    </div>

    <div class="space-y-5">
      {
        llcServicesFaq.map((item) => (
          <details class="group llc-card overflow-hidden !p-0">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 px-5 py-5 text-lg font-semibold text-slate-950 transition-colors hover:bg-slate-50/70 marker:hidden sm:px-6">
              <span>{item.question}</span>
              <span class="mt-1 text-slate-400 transition group-open:rotate-180">⌄</span>
            </summary>
            <div class="border-t border-slate-200 px-5 py-5 sm:px-6">
