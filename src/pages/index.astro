---
import StateSelector from '../components/state-selector.astro';
import SiteLayout from '../layouts/site-layout.astro';

const pageUrl = 'https://llcatlas.com/';
const title = 'LLCAtlas — Free LLC Formation Guides for Every State (2026)';
const description =
  "State-specific guides to forming your LLC. Real costs, honest recommendations, no hidden fees. Start with your state or compare the best LLC services.";
const differences = [
  "We start with your state, because that's what determines your fees, timeline, and requirements.",
  'Only honest recommendation, not a confusing list, because decision fatigue kills action.',
  'We show the real cost, not the advertised price, because $0 formation is never actually free.',
];
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: pageUrl,
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: pageUrl,
      },
    ],
  },
];
---

<SiteLayout title={title} description={description} structuredData={structuredData}>
  <section class="space-y-8">
    <div class="space-y-4">
      <h1>Form your LLC with clear guidance, not confusing upsells.</h1>
      <p class="text-lg leading-8 text-slate-700">
        LLCAtlas gives you free, state-specific guides to forming your LLC — and tells you exactly
        which service to use. No fluff. No $300 surprises.
      </p>
    </div>

    <div class="flex flex-col gap-4 sm:flex-row">
      <a
        href="#state-selector"
        class="inline-flex items-center justify-center rounded-full bg-amber-500 px-6 py-3 text-base font-semibold text-slate-950 transition hover:bg-amber-400"
      >
        Find your state guide
      </a>
      <a
        href="/best-llc-services"
        class="inline-flex items-center justify-center rounded-full border border-slate-300 px-6 py-3 text-base font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-slate-50"
      >
        Compare LLC services
      </a>
    </div>
  </section>

  <section id="state-selector" class="space-y-5 scroll-mt-8">
    <div class="space-y-3">
      <h2>Start with your state</h2>
      <p class="max-w-3xl text-lg leading-8 text-slate-700">
        LLC rules, fees, and timelines vary by state. Pick yours to see exactly what&apos;s involved.
      </p>
    </div>

    <StateSelector />
  </section>

  <section class="space-y-5">
    <div class="space-y-3">
      <h2>Not sure which LLC service to use?</h2>
      <p class="max-w-5xl text-lg leading-8 text-slate-700">
        Most services advertise $0 formation, then charge $200+ in add-ons. We compared the real year-one cost of the top providers so you don&apos;t have to.
      </p>
    </div>

    <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6 sm:p-7">
      <p class="text-xl font-semibold text-slate-950">
        Our #1 pick: Northwest Registered Agent — $39 + state fee, registered agent included
      </p>
      <p class="mt-3 max-w-3xl text-lg leading-8 text-slate-700">
        If you want a service instead of filing on your own, this is the cleanest place to start.
      </p>
      <a
        href="/best-llc-services"
        class="mt-4 inline-flex items-center text-base font-semibold text-amber-700 transition hover:text-amber-800"
      >
        See the full comparison →
      </a>
    </div>
  </section>

  <section class="space-y-4">
    <p class="max-w-3xl text-lg leading-8 text-slate-700">
      Most LLC sites dump you into a list of services and hope you click. We do the opposite:
    </p>

    <ul class="list-disc space-y-3 pl-6 text-lg leading-8 text-slate-700 marker:text-amber-600">
      {differences.map((item) => <li>{item}</li>)}
    </ul>
  </section>
</SiteLayout>
