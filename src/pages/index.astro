---
import StateSelector from '../components/state-selector.astro';
import SiteLayout from '../layouts/site-layout.astro';

const pageUrl = 'https://llcatlas.com/';
const title = 'LLCAtlas — Free LLC Formation Guides for Every State (2026)';
const description =
  'Free LLC formation guides by state, with real filing costs, plain-English steps, honest service comparisons, and no hidden-fee advice.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: pageUrl,
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: pageUrl,
      },
    ],
  },
];
---

<SiteLayout title={title} description={description} structuredData={structuredData}>
  <section class="space-y-8">
    <div class="space-y-4">
      <h1>LLC formation guides without the upsells.</h1>
      <p class="max-w-3xl text-lg leading-8 text-ink-soft">
        Most first-time owners don't need more options. You need LLC formation guides with the
        filing steps in plain English, real costs up front, and an honest next step.
      </p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6">
      <a
        href="#state-selector"
        class="inline-flex min-h-11 items-center justify-center rounded-full bg-accent px-6 py-3 text-base font-semibold text-ink-strong transition hover:bg-accent/85"
      >
        Find your state guide
      </a>
      <a
        href="/best-llc-services/"
        class="inline-flex items-center text-base font-medium text-ink-soft underline decoration-rule-strong underline-offset-4 transition hover:text-ink-strong hover:decoration-ink-muted"
      >
        Already decided you want help? Compare services
        <span aria-hidden="true" class="ml-1.5">→</span>
      </a>
    </div>
  </section>

  <section id="state-selector" class="space-y-5 scroll-mt-8">
    <div class="space-y-3">
      <h2>LLC formation guides by state</h2>
      <p class="max-w-3xl text-lg leading-8 text-ink-soft">
        Filing fees, annual reports, processing times, and the extra steps a few states still
        require. They all change depending on where you form. Pick your state to see what filing
        actually looks like.
      </p>
    </div>

    <StateSelector />
  </section>

  <section aria-labelledby="approach-heading" class="border-t border-rule pt-8 sm:pt-10">
    <div class="max-w-3xl space-y-3">
      <p class="llc-helper">How we approach this</p>
      <h2 id="approach-heading" class="!text-2xl">Framework first. Click second.</h2>
      <p class="text-lg leading-8 text-ink-soft">
        Most LLC sites want the click first and the explanation later. We give you the framework
        first — what filing actually involves, what each state requires, where the real costs hide
        — and then let you pick. If you want help with the paperwork, our{' '}
        <a
          href="/best-llc-services/"
          class="font-semibold text-ink-strong underline decoration-rule-strong underline-offset-4 transition hover:text-ink-soft hover:decoration-ink-muted"
        >
          comparison of LLC services
        </a>{' '}
        ranks them by year-one cost and how much they actually do for you.
      </p>
    </div>
  </section>
</SiteLayout>
